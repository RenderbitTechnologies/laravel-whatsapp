{
    "name": "renderbit/laravel-whatsapp",
    "version": "1.0.2",
    "description": "Framework-agnostic PHP library for sending WhatsApp messages via Renderbit, with Laravel support.",
    "type": "library",
    "license": "MIT",
    "keywords": ["whatsapp", "laravel", "renderbit", "api", "messaging"],
    "homepage": "https://github.com/renderbit/laravel-whatsapp",
    "support": {
        "issues": "https://github.com/RenderbitTechnologies/laravel-whatsapp/issues",
        "source": "https://github.com/RenderbitTechnologies/laravel-whatsapp"
    },
    "authors": [
        {
            "name": "Aditya V Jajodia",
            "email": "aditya.v.jajodia@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.9",
        "illuminate/support": "^10.0 || ^11.0",
        "psr/log": "^1.1 || ^2.0 || ^3.0",
        "psr/simple-cache": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Renderbit\\LaravelWhatsapp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Renderbit\\LaravelWhatsapp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Renderbit\\LaravelWhatsapp\\WhatsappServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "audit": {
            "ignore": ["[\"PKSA-m5cs-t1y6-qpcs\", \"PKSA-3r5d-mb8f-1qw9\", \"PKSA-mdq4-51ck-6kdq\", \"PKSA-8qx3-n5y5-vvnd\", \"PKSA-q46n-4fdk-zjr4\", \"PKSA-qzrn-rnz3-85w1\", \"PKSA-w7xr-vk7n-rstm\"]"]
        }
    }
}
